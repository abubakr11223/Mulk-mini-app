generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model House {
  id        Int      @id @default(autoincrement())
  lat       Float
  lng       Float
  price     String
  hot       Boolean  @default(false)
  createdAt DateTime @default(now())
}
