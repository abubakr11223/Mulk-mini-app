generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model House {
  id          Int      @id @default(autoincrement())
  crmId       String?  @unique
  lat         Float
  lng         Float
  price       String
  hot         Boolean  @default(false)
  image       String   @default("https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&q=80")
  title       String   @default("Mulk")
  description String   @default("Rieltorlar uchun maxsus yopiq mulk.")
  rooms       Int      @default(0)
  area        Float    @default(0)
  floor       Int      @default(0)
  createdAt   DateTime @default(now())
}
